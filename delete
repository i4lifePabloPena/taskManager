router.get('/tasks', authMiddleware, async (req, res) => {
    try {
        const { status } = req.query;  // Lee el parámetro ?status=0 de la URL
        let filter = { userId: req.userId };  // Filtro base: solo tareas del usuario
        
        // Si se pasa status, añádelo al filtro (y valida que sea un número)
        if (status !== undefined) {
            const statusNum = parseInt(status, 10);
            if (isNaN(statusNum) || statusNum < 0 || statusNum > 2) {
                return res.status(400).json({ error: 'Status inválido. Debe ser 0, 1 o 2.' });
            }
            filter.status = statusNum;  // Añade el filtro por status
        }
        
        const tasks = await Task.find(filter);  // Aplica el filtro completo
        res.json(tasks);
    } catch (error) {
        res.status(500).json({ error: 'Error al obtener tareas' });
    }
});